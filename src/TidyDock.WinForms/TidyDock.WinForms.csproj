<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>TidyDock</AssemblyName>
    <RootNamespace>TidyDock.WinForms</RootNamespace>
    <ApplicationIcon>..\TidyDock\assets\TidyDock.ico</ApplicationIcon>
    <Version>0.2.0</Version>
    <FileVersion>0.2.0.0</FileVersion>
    <AssemblyVersion>0.2.0.0</AssemblyVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="installer\**\*.cs" />
    <Content Include="..\TidyDock\assets\TidyDock.ico" Link="assets\TidyDock.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
